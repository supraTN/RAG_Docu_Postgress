# ── OpenAI ──
OPENAI_API_KEY=sk-proj-your-key-here

# ── Database ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag_postgresql_docs

# ── Backend (optional — defaults shown) ──
LLM_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
COLLECTION_NAME=postgres_docs_v6
BASE_DOC_URL=https://www.postgresql.org/docs/16/
SIMILARITY_THRESHOLD=0.3
RERANKER_ENABLED=true
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
ALLOWED_ORIGINS=http://localhost:3000

# ── Data processing (optional) ──
# POSTGRES_DOCS_DIR is auto-detected from any postgresql-*/ folder at the project root.
# Override only if your docs are in a custom location.
# POSTGRES_DOCS_DIR=./postgresql-16.10/doc/src/sgml/html
OUTPUT_FILE=postgres_rag_data_v6_perfect.json

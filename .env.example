# ── OpenAI ──
OPENAI_API_KEY=sk-proj-your-key-here

# ── Database ──
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/rag_postgresql_docs

# ── Backend (optional — defaults shown) ──
LLM_MODEL=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-large
COLLECTION_NAME=postgres_docs_v10
BASE_DOC_URL=https://www.postgresql.org/docs/16/
SIMILARITY_THRESHOLD=0.3
RERANKER_ENABLED=true
COHERE_API_KEY=your-cohere-api-key-here
COHERE_RERANK_MODEL=rerank-v4.0-fast
FALLBACK_RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RERANKER_THRESHOLD=0.5
RERANKER_SCORE_RATIO=0.8
ALLOWED_ORIGINS=http://localhost:3000

# ── Benchmark (optional) ──
BENCHMARK_JUDGE_MODEL=gpt-4.1-mini
